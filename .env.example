# HMS environment template
# Copy this file to .env and replace the *_change_me values.
# Never commit the populated .env file.

# Public URL handed to vendors after deployment. For local smoke tests keep this
# aligned with PUBLIC_HTTP_PORT.
PUBLIC_BASE_URL=http://localhost:8080
PUBLIC_HTTP_PORT=8080

# PostgreSQL. The compose file does not publish this port.
POSTGRES_USER=hms
POSTGRES_PASSWORD=hms_postgres_password_change_me
POSTGRES_DB=hms
HMS_API_DATABASE_BACKEND=postgresql
HMS_API_DATABASE_URL=postgresql://hms:hms_postgres_password_change_me@postgres:5432/hms
HMS_API_DATABASE_SCHEMA=public
HMS_API_VECTOR_EXTENSION=pgvector

# Optional external dense semantic index. PostgreSQL remains canonical and
# continues to provide full-text/BM25 search and SQL fallback.
# Install the `milvus` extra before enabling this provider.
# HMS_API_VECTOR_INDEX_PROVIDER=milvus
# HMS_API_MILVUS_URI=./hms_milvus.db
# HMS_API_MILVUS_TOKEN=
# HMS_API_MILVUS_DB_NAME=
# HMS_API_MILVUS_COLLECTION=hms_memory_units
# HMS_API_MILVUS_CONSISTENCY_LEVEL=Session

# Existing multipart file-ingestion contract. Keep multimodal opt-in by
# selecting `openai_multimodal` explicitly in the upload request.
HMS_API_ENABLE_FILE_UPLOAD_API=true
HMS_API_FILE_PARSER=markitdown
# HMS_API_FILE_PARSER_ALLOWLIST=markitdown,openai_multimodal
HMS_API_FILE_CONVERSION_MAX_BATCH_SIZE_MB=100
HMS_API_FILE_CONVERSION_MAX_BATCH_SIZE=10
HMS_API_FILE_DELETE_AFTER_RETAIN=true

# Opt-in image/video description role. It is separate from text retain because
# it uses Responses API image parts and strict structured output. The current
# media runtime support matrix is PostgreSQL; Oracle text-memory support is
# unaffected, while Oracle + multimodal fails closed.
HMS_API_MULTIMODAL_ENABLED=false
HMS_API_MULTIMODAL_PROVIDER=openai
HMS_API_MULTIMODAL_MODEL=gpt-5-mini
HMS_API_MULTIMODAL_MODEL_BEHAVIOR_VERSION=gpt-5-mini-alias-v1
HMS_API_MULTIMODAL_API_KEY=
HMS_API_MULTIMODAL_BASE_URL=https://api.openai.com/v1
HMS_API_MULTIMODAL_IMAGE_ENABLED=true
# Video is decoded locally into selected images and requires the optional
# decoder dependency in every API/worker image.
HMS_API_MULTIMODAL_VIDEO_ENABLED=false
HMS_API_MULTIMODAL_LIVE_VERIFIED=false
HMS_API_MULTIMODAL_CAPABILITY_RESPONSES_API=true
HMS_API_MULTIMODAL_CAPABILITY_IMAGE_INPUT=true
HMS_API_MULTIMODAL_CAPABILITY_STRUCTURED_OUTPUTS=true
HMS_API_MULTIMODAL_IMAGE_DETAIL=auto
HMS_API_MULTIMODAL_MAX_IMAGE_BYTES=20971520
HMS_API_MULTIMODAL_MAX_IMAGE_PIXELS=40000000
HMS_API_MULTIMODAL_MAX_VIDEO_BYTES=104857600
HMS_API_MULTIMODAL_MAX_VIDEO_DURATION_SECONDS=600
HMS_API_MULTIMODAL_VIDEO_PROBE_INTERVAL_SECONDS=1
HMS_API_MULTIMODAL_VIDEO_MAX_FRAMES=24
HMS_API_MULTIMODAL_VIDEO_COVERAGE_RATIO=0.6
HMS_API_MULTIMODAL_MAX_FRAMES_PER_CALL=8
HMS_API_MULTIMODAL_MAX_OUTPUT_TOKENS=4096
HMS_API_MULTIMODAL_REQUEST_TIMEOUT_SECONDS=60
HMS_API_MULTIMODAL_MAX_RETRIES=2
HMS_API_MULTIMODAL_MAX_SCHEMA_REPAIRS=1
HMS_API_MULTIMODAL_MAX_CONCURRENCY=4
HMS_API_MULTIMODAL_DESCRIPTOR_CACHE_TTL_SECONDS=604800
HMS_API_MULTIMODAL_PROMPT_VERSION=openai-mm-v2
HMS_API_MULTIMODAL_SCHEMA_VERSION=hms-multimodal-v1
HMS_API_MULTIMODAL_SAMPLING_VERSION=scene-coverage-v1

# Internal HMS API. Do not hand this key to vendors.
HMS_API_HOST=0.0.0.0
HMS_API_PORT=18080
HMS_API_LOG_LEVEL=info
HMS_API_LOG_FORMAT=json
HMS_API_TENANT_EXTENSION=hms_api.extensions.builtin.tenant:ApiKeyTenantExtension
HMS_API_TENANT_API_KEY=hms_internal_change_me
HMS_API_WORKER_ENABLED=true
HMS_API_RUN_MIGRATIONS_ON_STARTUP=true

# Local endpoint used by SDK wrappers and one-click examples.
HMS_LOCAL_API_PORT=18080
HMS_MEMORY_API_URL=http://127.0.0.1:18080
HMS_MEMORY_API_KEY=hms_internal_change_me
HMS_MEMORY_BANK_ID=automatic-memory-demo

# Wrapped OpenAI client. If omitted, the demo falls back to HMS_API_LLM_*.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Core HMS model used by memory reasoning, recall organization, and reflection.
HMS_API_LLM_PROVIDER=openai
HMS_API_LLM_MODEL=gpt-4o
HMS_API_LLM_API_KEY=openai_key_change_me
HMS_API_LLM_BASE_URL=https://api.openai.com/v1

# Retain model used for ingestion and structured fact extraction.
HMS_API_RETAIN_LLM_PROVIDER=openai
HMS_API_RETAIN_LLM_MODEL=gpt-4o
HMS_API_RETAIN_LLM_API_KEY=openai_key_change_me
HMS_API_RETAIN_LLM_BASE_URL=https://api.openai.com/v1

# Embeddings and lightweight RRF reranking.
HMS_API_EMBEDDINGS_PROVIDER=openai
HMS_API_EMBEDDINGS_OPENAI_MODEL=text-embedding-3-small
HMS_API_EMBEDDINGS_OPENAI_API_KEY=openai_key_change_me
HMS_API_EMBEDDINGS_OPENAI_BASE_URL=https://api.openai.com/v1
HMS_API_RERANKER_PROVIDER=rrf

# Gateway service. Only Nginx exposes this service publicly.
HMS_GATEWAY_HOST=0.0.0.0
HMS_GATEWAY_PORT=18081
HMS_INTERNAL_BASE_URL=http://hms-api:18080
HMS_INTERNAL_API_KEY=hms_internal_change_me
HMS_GATEWAY_API_KEYS=hms_live_vendor_a_change_me,hms_live_vendor_b_change_me
HMS_GATEWAY_RATE_LIMIT_PER_MINUTE=60
HMS_GATEWAY_DAILY_QUOTA=1000
HMS_GATEWAY_AUDIT_LOG=/app/logs/vendor_gateway_audit.jsonl
HMS_GATEWAY_SCOPE_BANK_IDS=true
HMS_GATEWAY_CHECK_INTERNAL_HEALTH=true
HMS_GATEWAY_INTERNAL_TIMEOUT=600
HMS_GATEWAY_MAX_SESSIONS_PER_REQUEST=100
HMS_GATEWAY_MAX_MESSAGES_PER_SESSION=100
HMS_GATEWAY_MAX_MESSAGE_CHARS=20000
HMS_GATEWAY_MAX_QUESTION_CHARS=4000

# Optional smoke test behavior.
HMS_SMOKE_RUN_PIPELINE=0
HMS_SMOKE_BANK_ID=vendor-smoke
